        {
          "name": "1. Register Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"full_name\": \"Test Admin\",\n  \"email\": \"admin@crm.com\",\n  \"phone\": \"9876543210\",\n  \"password\": \"securepassword123\"\n}" },
            "url": { "raw": "http://localhost:5000/api/auth/register", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "auth", "register"] }
          }
        },
        {
