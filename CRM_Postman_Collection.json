            "body": { "mode": "raw", "raw": "{\n  \"business_name\": \"TechCorp\",\n  \"business_email\": \"contact@techcorp.com\",\n  \"registration_number\": \"REG123\",\n  \"gst_number\": \"GST456\",\n  \"tax_id\": \"TAX789\",\n  \"country\": \"India\",\n  \"state\": \"Maharashtra\",\n  \"city\": \"Mumbai\",\n  \"pincode\": \"400001\"\n}" },
