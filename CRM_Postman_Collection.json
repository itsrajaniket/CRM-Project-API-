            ],
            "body": { "mode": "raw", "raw": "{\n  \"full_name\": \"John Doe\",\n  \"phone_number\": \"123-456-7890\",\n  \"email_id\": \"john@example.com\",\n  \"customer_interaction\": \"New Lead\"\n}" },
            "url": { "raw": "http://localhost:5000/api/leads", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["api", "leads"] }
          }
        },
        {
          "name": "2. Get All Leads",
